#!/usr/bin/env bash
# tmux-sessionizer - Fuzzy project switcher
#
# Based on ThePrimeagen's sessionizer with a default 3-pane layout.

SEARCH_DIRS=(
    ~/software
)

if [[ $# -eq 1 ]]; then
    selected=$1
else
    selected=$(find "${SEARCH_DIRS[@]}" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | fzf)
fi

[[ -z $selected ]] && exit 0

selected_name=$(basename "$selected" | tr . _)

if ! tmux has-session -t="$selected_name" 2>/dev/null; then
    tmux new-session -ds "$selected_name" -c "$selected"
    tmux send-keys -t "$selected_name:1.1" "nvim ." C-m
    tmux split-window -t "$selected_name:1.1" -h -l 40% -c "$selected"
    tmux send-keys -t "$selected_name:1.2" "claude" C-m
    tmux split-window -t "$selected_name:1.2" -v -l 30% -c "$selected"
    tmux select-pane -t "$selected_name:1.1"
fi

if [[ -z $TMUX ]]; then
    tmux attach-session -t "$selected_name"
else
    tmux switch-client -t "$selected_name"
fi
