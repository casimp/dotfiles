#!/usr/bin/env bash
# tmux-sessionizer - Fuzzy project switcher with default layout
#
# Usage:
#   tmux-sessionizer          # interactive fzf selection
#   tmux-sessionizer ~/path   # jump directly to path
#
# Layout priority:
#   1. Project's .tmux-layout file (if exists)
#   2. Default layout: work (nvim|claude|term), spare term

SEARCH_DIRS=(
    ~/software
)

# --- Layout functions ---

apply_layout() {
    local session=$1
    local dir=$2
    local layout_file="$dir/.tmux-layout"

    if [[ -f "$layout_file" ]]; then
        custom_layout "$session" "$dir" "$layout_file"
    else
        default_layout "$session" "$dir"
    fi
}

default_layout() {
    local session=$1
    local dir=$2

    # Window 1 "work": nvim (left 60%) | claude (right top) | terminal (right bottom)
    tmux rename-window -t "$session:1" "work"
    tmux send-keys -t "$session:work" "nvim ." C-m
    tmux split-window -t "$session:work" -h -p 40 -c "$dir"
    tmux send-keys -t "$session:work.2" "claude" C-m
    tmux split-window -t "$session:work.2" -v -p 30 -c "$dir"

    # Window 2 "term": spare shell
    tmux new-window -t "$session" -n "term" -c "$dir"

    # Go back to work window
    tmux select-window -t "$session:work"
    tmux select-pane -t "$session:work.1"
}

custom_layout() {
    local session=$1
    local dir=$2
    local layout_file=$3
    local first_window=true

    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ "$line" =~ ^[[:space:]]*# ]] && continue
        [[ -z "${line// }" ]] && continue

        local wname="${line%%:*}"
        local wcmd="${line#*: }"
        wname=$(echo "$wname" | xargs)
        wcmd=$(echo "$wcmd" | xargs)

        if $first_window; then
            tmux rename-window -t "$session:1" "$wname"
            first_window=false
        else
            tmux new-window -t "$session" -n "$wname" -c "$dir"
        fi

        if [[ -n "$wcmd" && "$wcmd" != "$wname" ]]; then
            tmux send-keys -t "$session:$wname" "$wcmd" C-m
        fi
    done < "$layout_file"

    tmux select-window -t "$session:1"
}

# --- Main ---

if [[ $# -eq 1 ]]; then
    selected=$1
else
    selected=$(find "${SEARCH_DIRS[@]}" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | fzf)
fi

if [[ -z $selected ]]; then
    exit 0
fi

selected_name=$(basename "$selected" | tr . _)
tmux_running=$(pgrep tmux)

if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
    tmux new-session -s "$selected_name" -c "$selected"
    apply_layout "$selected_name" "$selected"
    exit 0
fi

if ! tmux has-session -t="$selected_name" 2>/dev/null; then
    tmux new-session -ds "$selected_name" -c "$selected"
    apply_layout "$selected_name" "$selected"
fi

if [[ -z $TMUX ]]; then
    tmux attach-session -t "$selected_name"
else
    tmux switch-client -t "$selected_name"
fi
