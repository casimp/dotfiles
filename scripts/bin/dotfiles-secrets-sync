#!/usr/bin/env bash
# dotfiles-secrets-sync - Pull secrets from Bitwarden into ~/.bash_local
#
# Prerequisites: Install Bitwarden CLI
#   npm install -g @bitwarden/cli
#   OR snap install bw
#
# Setup: Create items in Bitwarden with these names (adjust as needed):
#   - "GITHUB_TOKEN"
#   - "AWS_ACCESS_KEY_ID"
#   - "AWS_SECRET_ACCESS_KEY"
#
# The script pulls passwords from items matching these names and writes
# them as exports to ~/.bash_local

set -euo pipefail

BASH_LOCAL="$HOME/.bash_local"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
info()  { echo -e "\033[0;34m[info]\033[0m  $*"; }
ok()    { echo -e "\033[0;32m[ok]\033[0m    $*"; }
warn()  { echo -e "\033[0;33m[warn]\033[0m  $*"; }
error() { echo -e "\033[0;31m[error]\033[0m $*" >&2; }

# ---------------------------------------------------------------------------
# Bitwarden secrets to sync
# Add entries here as: "BITWARDEN_ITEM_NAME:ENV_VAR_NAME"
# ---------------------------------------------------------------------------
SECRETS=(
    "GITHUB_TOKEN:GITHUB_TOKEN"
    "AWS_ACCESS_KEY_ID:AWS_ACCESS_KEY_ID"
    "AWS_SECRET_ACCESS_KEY:AWS_SECRET_ACCESS_KEY"
    "AWS_DEFAULT_REGION:AWS_DEFAULT_REGION"
)

# ---------------------------------------------------------------------------
# Preflight checks
# ---------------------------------------------------------------------------
if ! command -v bw &>/dev/null; then
    error "Bitwarden CLI (bw) is not installed."
    echo "  Install with: npm install -g @bitwarden/cli"
    echo "  Or:           snap install bw"
    exit 1
fi

# ---------------------------------------------------------------------------
# Login / unlock
# ---------------------------------------------------------------------------
BW_STATUS=$(bw status 2>/dev/null | grep -oP '"status":"\K[^"]+' || echo "unauthenticated")

if [[ "$BW_STATUS" == "unauthenticated" ]]; then
    info "Logging in to Bitwarden..."
    export BW_SESSION=$(bw login --raw)
elif [[ "$BW_STATUS" == "locked" ]]; then
    info "Unlocking Bitwarden vault..."
    export BW_SESSION=$(bw unlock --raw)
elif [[ "$BW_STATUS" == "unlocked" ]]; then
    info "Bitwarden vault is already unlocked"
else
    error "Unknown Bitwarden status: $BW_STATUS"
    exit 1
fi

# Sync vault
info "Syncing vault..."
bw sync &>/dev/null

# ---------------------------------------------------------------------------
# Pull secrets
# ---------------------------------------------------------------------------
info "Writing secrets to $BASH_LOCAL"

cat > "$BASH_LOCAL" <<'HEADER'
# ~/.bash_local - Auto-generated by dotfiles-secrets-sync
# Do not edit manually -- re-run dotfiles-secrets-sync to update
# This file is NOT tracked in git

HEADER

synced=0
skipped=0

for entry in "${SECRETS[@]}"; do
    bw_name="${entry%%:*}"
    env_name="${entry##*:}"

    value=$(bw get password "$bw_name" 2>/dev/null || echo "")

    if [[ -n "$value" ]]; then
        echo "export ${env_name}=\"${value}\"" >> "$BASH_LOCAL"
        ok "$env_name"
        ((synced++))
    else
        warn "Item '$bw_name' not found in vault -- skipping $env_name"
        echo "# export ${env_name}=\"\"  # not found in vault" >> "$BASH_LOCAL"
        ((skipped++))
    fi
done

chmod 600 "$BASH_LOCAL"

echo ""
info "Done! Synced: $synced, Skipped: $skipped"
info "Restart your shell or run: source ~/.bash_local"
